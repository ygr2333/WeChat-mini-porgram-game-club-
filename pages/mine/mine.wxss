.page {
  padding: 24rpx;
}

.user-card {
  background: linear-gradient(135deg, #3b82f6, #2563eb);
  border-radius: 28rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.user-info {
  color: #ffffff;
}

.user-name {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.user-id {
  font-size: 24rpx;
  opacity: 0.9;
}

.group-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #222;
  margin-bottom: 20rpx;
}

.action-list {
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
}

.action-item {
  height: 94rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #f2f4f7;
}

.action-item:last-child {
  border-bottom: none;
}

.action-name {
  font-size: 28rpx;
  color: #222;
}

.action-arrow {
  font-size: 34rpx;
  color: #a0a0a0;
}