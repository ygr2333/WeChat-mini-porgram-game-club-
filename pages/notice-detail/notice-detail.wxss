.page {
  padding: 24rpx;
}

.detail-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
}

.detail-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #222;
  line-height: 1.5;
  margin-bottom: 14rpx;
}

.detail-time {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 24rpx;
}

.detail-content {
  font-size: 28rpx;
  color: #555;
  line-height: 1.9;
}

.state-wrap {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 70rpx 20rpx;
  text-align: center;
}

.state-text {
  font-size: 26rpx;
  color: #999;
}