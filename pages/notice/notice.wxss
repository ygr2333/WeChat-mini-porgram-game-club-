.page {
  padding: 24rpx;
}

.page-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #222;
  margin-bottom: 24rpx;
}

.notice-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.notice-header {
  margin-bottom: 16rpx;
}

.notice-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #222;
  margin-bottom: 8rpx;
}

.notice-time {
  font-size: 24rpx;
  color: #999;
}

.notice-content {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
}

.state-wrap {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 70rpx 20rpx;
  text-align: center;
}

.state-text {
  font-size: 26rpx;
  color: #999;
}

.notice-link {
  margin-top: 18rpx;
  font-size: 24rpx;
  color: #3b82f6;
}