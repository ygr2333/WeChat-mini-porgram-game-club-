<view class="page">
  <view class="page-title">最新公告</view>

  <view wx:if="{{loading}}" class="state-wrap">
    <view class="state-text">加载中...</view>
  </view>

  <block wx:elif="{{list.length > 0}}">
    <block wx:for="{{list}}" wx:key="id">
      <view class="notice-card" bindtap="goDetail" data-id="{{item.id}}">
        <view class="notice-header">
          <view class="notice-title">{{item.title}}</view>
          <view class="notice-time">{{item.time}}</view>
        </view>
        <view class="notice-content">{{item.content}}</view>
        <view class="notice-link">查看详情 ></view>
      </view>
    </block>
  </block>

  <view wx:else class="state-wrap">
    <view class="state-text">暂无公告</view>
  </view>
</view>