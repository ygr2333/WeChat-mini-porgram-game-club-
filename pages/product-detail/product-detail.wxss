.page {
  padding: 24rpx;
}

.product-card {
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
}

.product-image {
  width: 100%;
  height: 420rpx;
  display: block;
}

.product-info {
  padding: 24rpx;
}

.product-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #222;
  line-height: 1.5;
  margin-bottom: 18rpx;
}

.price-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 20rpx;
}

.price-now {
  font-size: 34rpx;
  font-weight: 700;
  color: #ff5a5f;
}

.price-old {
  font-size: 24rpx;
  color: #aaa;
  text-decoration: line-through;
}

.product-desc {
  font-size: 27rpx;
  color: #555;
  line-height: 1.9;
  margin-bottom: 28rpx;
}

.contact-btn {
  height: 84rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #3b82f6, #2563eb);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.state-wrap {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 70rpx 20rpx;
  text-align: center;
}

.state-text {
  font-size: 26rpx;
  color: #999;
}