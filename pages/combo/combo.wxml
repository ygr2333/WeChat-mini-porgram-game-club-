<view class="page">
  <view class="page-title">推荐套餐</view>

  <view wx:if="{{loading}}" class="state-wrap">
    <view class="state-text">加载中...</view>
  </view>

  <block wx:elif="{{list.length > 0}}">
    <block wx:for="{{list}}" wx:key="id">
      <view class="combo-card" bindtap="goDetail" data-id="{{item.id}}">
        <view class="combo-name">{{item.name}}</view>
        <view class="combo-desc">{{item.desc}}</view>
        <view class="combo-price">￥{{item.price}}</view>
        <view class="combo-link">查看详情 ></view>
      </view>
    </block>
  </block>

  <view wx:else class="state-wrap">
    <view class="state-text">暂无套餐</view>
  </view>
</view>