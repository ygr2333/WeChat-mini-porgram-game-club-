.page {
  padding: 24rpx;
}

.page-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #222;
  margin-bottom: 24rpx;
}

.combo-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.combo-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #222;
  margin-bottom: 12rpx;
}

.combo-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
  margin-bottom: 16rpx;
}

.combo-price {
  font-size: 32rpx;
  font-weight: 700;
  color: #ff5a5f;
}

.state-wrap {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 70rpx 20rpx;
  text-align: center;
}

.state-text {
  font-size: 26rpx;
  color: #999;
}

.combo-link {
  margin-top: 18rpx;
  font-size: 24rpx;
  color: #3b82f6;
}