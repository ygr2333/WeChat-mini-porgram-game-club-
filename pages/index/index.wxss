page {
  background: #f6f7fb;
}

.page {
  padding: 20rpx 20rpx 30rpx;
}

.header {
  padding: 12rpx 0 18rpx;
  text-align: center;
}

.header-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.search-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 22rpx;
}

.search-box {
  flex: 1;
  height: 72rpx;
  background: #ffffff;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
}

.search-icon {
  color: #bdbdbd;
  font-size: 30rpx;
  margin-right: 14rpx;
}

.search-input {
  flex: 1;
  height: 72rpx;
  font-size: 26rpx;
}

.search-placeholder {
  color: #b7b7b7;
}

.search-btn {
  width: 120rpx;
  height: 72rpx;
  border-radius: 36rpx;
  background: linear-gradient(135deg, #19d28f, #10b981);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.banner-swiper {
  width: 100%;
  height: 260rpx;
  border-radius: 24rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.notice-bar {
  height: 72rpx;
  background: #ffffff;
  border-radius: 18rpx;
  padding: 0 20rpx;
  display: flex;
  align-items: center;
  margin-bottom: 26rpx;
}

.notice-icon {
  font-size: 28rpx;
  margin-right: 14rpx;
}

.notice-text {
  flex: 1;
  font-size: 25rpx;
  color: #555;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.menu-section {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 26rpx 10rpx 14rpx;
  display: flex;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.menu-item {
  width: 20%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.menu-icon {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  background: #eef4fb;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
  font-size: 32rpx;
}

.menu-name {
  font-size: 22rpx;
  color: #4b5563;
  text-align: center;
  line-height: 1.35;
}

.section-header {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #222;
}

.product-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  padding-bottom: 20rpx;
}

.product-card {
  width: 48.3%;
  background: #ffffff;
  border-radius: 22rpx;
  overflow: hidden;
  margin-bottom: 22rpx;
}

.product-image {
  width: 100%;
  height: 240rpx;
  display: block;
}

.product-name {
  font-size: 28rpx;
  color: #222;
  line-height: 1.5;
  min-height: 78rpx;
  padding: 18rpx 18rpx 6rpx;
}

.product-meta {
  padding: 0 18rpx;
  font-size: 22rpx;
  color: #999;
}

.product-price-row {
  padding: 12rpx 18rpx 20rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.product-price {
  font-size: 30rpx;
  font-weight: 700;
  color: #ff5a5f;
}

.product-old-price {
  font-size: 22rpx;
  color: #b8b8b8;
  text-decoration: line-through;
}

.empty-wrap {
  background: #ffffff;
  border-radius: 22rpx;
  padding: 60rpx 20rpx;
  text-align: center;
}

.empty-text {
  font-size: 26rpx;
  color: #999;
}